{
  "name": "kalam",
  "version": "0.1.0-beta.2",
  "description": "Kalam — open-source voice dictation for Windows, macOS & Linux. Free, privacy-friendly alternative to Whisperflow. Speaks into any app.",
  "type": "module",
  "keywords": [
    "voice-dictation",
    "speech-to-text",
    "stt",
    "whisperflow-alternative",
    "open-source",
    "privacy",
    "cross-platform",
    "tauri",
    "dictation",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/afaraha8403/kalam.git"
  },
  "homepage": "https://github.com/afaraha8403/kalam#readme",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/afaraha8403/kalam/issues"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && tauri dev -f dev-bridge",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docs:dev": "serve docs -l 4321",
    "tauri": "tauri",
    "tauri:build": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && tauri build",
    "tauri:build:unsigned": "tauri build --no-sign",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run",
    "test:stt": "cargo test --manifest-path ./src-tauri/Cargo.toml --test stt_integration_tests",
    "test:e2e": "start-server-and-test dev:vite http://localhost:5173 cypress run",
    "test:e2e:open": "start-server-and-test dev:vite http://localhost:5173 cypress open",
    "kill": "node scripts/kill-project.js"
  },
  "dependencies": {
    "@iconify/svelte": "^3.1.6",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-sql": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-bubble-menu": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/suggestion": "^2.27.2",
    "apexcharts": "^5.10.4",
    "dompurify": "^3.3.2",
    "gsap": "^3.14.2",
    "marked": "^17.0.4",
    "posthog-js": "^1.359.0",
    "rrule": "^2.8.1",
    "svelty-picker": "^5.2.12",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/dompurify": "^3.0.5",
    "autoprefixer": "^10.4.0",
    "cypress": "^15.12.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "serve": "^14.2.4",
    "start-server-and-test": "^2.1.5",
    "svelte": "^4.2.0",
    "svelte-check": "^4.0.0",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
